DRONE_BASE_URL=https://drone.example.com
DRONE_TOKEN=replace-with-drone-token
DRONE_WEBHOOK_SECRET=replace-with-webhook-secret
DRONE_TIMEOUT_MS=10000
DRONE_MAX_RETRIES=2
DRONE_MAX_RESPONSE_BYTES=2000000
MCP_ENABLE_WRITE_ACTIONS=false
MCP_WEBHOOK_PORT=0
MCP_WEBHOOK_HOST=127.0.0.1
MCP_WEBHOOK_PATH=/webhook/drone
MCP_WEBHOOK_MAX_BODY_BYTES=1000000
MCP_RECONCILE_INTERVAL_MS=0
MCP_BUILD_STATE_MAX_SNAPSHOTS=1000
MCP_BUILD_STATE_MAX_SNAPSHOTS_PER_REPO=200
